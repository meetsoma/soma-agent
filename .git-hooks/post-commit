#!/usr/bin/env bash
# post-commit — Auto-changelog + restart-required detection
#
# Two jobs:
#   1. Append feat/fix entries to CHANGELOG.md [Unreleased]
#   2. Signal restart-required when core/extension files change
#
# Related: soma-dev.sh (reads signal), soma-statusline.ts (displays indicator)
set -euo pipefail

# ── Job 1: Changelog auto-append ──────────────────────────────────

CHANGELOG="CHANGELOG.md"
if [[ -f "$CHANGELOG" ]]; then
  MSG=$(git log --format="%s" -1 HEAD)
  HASH=$(git log --format="%h" -1 HEAD)

  if echo "$MSG" | grep -qE "^(feat|fix)\(" && ! echo "$MSG" | grep -qiE "^docs\(changelog\)"; then
    TYPE=$(echo "$MSG" | sed 's/^\([a-z]*\)(.*/\1/')
    DESC=$(echo "$MSG" | sed 's/^[a-z]*([^)]*): //')

    [[ "$TYPE" == "feat" ]] && SECTION="### Added" || SECTION="### Fixed"

    KEY=$(echo "$DESC" | sed 's/[—–]//g' | awk '{for(i=1;i<=3&&i<=NF;i++) printf "%s ", $i}' | sed 's/ $//')
    if ! grep -qiF "$KEY" "$CHANGELOG" 2>/dev/null; then
      ENTRY="- **${DESC}**"
      if grep -q "^$SECTION" "$CHANGELOG"; then
        sed -i '' "/^$SECTION$/a\\
$ENTRY
" "$CHANGELOG"
      else
        sed -i '' "/^## \[Unreleased\]$/a\\
\\
$SECTION\\
$ENTRY
" "$CHANGELOG"
      fi
      echo "📝 Changelog: auto-appended $TYPE entry"
    fi
  fi
fi

# ── Job 2: Restart-required detection ─────────────────────────────

CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null || true)

NEEDS_RESTART=false
CHANGED_FILES=""
while IFS= read -r file; do
  case "$file" in
    extensions/*.ts|core/*.ts|core/*.js)
      NEEDS_RESTART=true
      CHANGED_FILES="${CHANGED_FILES}${file} "
      ;;
  esac
done <<< "$CHANGED"

if $NEEDS_RESTART; then
  # Find .soma dir — walk up from repo root
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
  SOMA_SIGNAL=""

  for candidate in \
    "$REPO_ROOT/../../.soma/.restart-required" \
    "$REPO_ROOT/../../../.soma/.restart-required"; do
    parent=$(dirname "$candidate")
    if [[ -d "$parent" ]]; then
      SOMA_SIGNAL="$candidate"
      break
    fi
  done

  if [[ -n "$SOMA_SIGNAL" ]]; then
    COMMIT_INFO=$(git log --format='%h %s' -1 HEAD)
    cat > "$SOMA_SIGNAL" << EOF
timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)
commit: $COMMIT_INFO
files: $CHANGED_FILES
EOF
    echo "🔄 Restart required — core/extension files changed"

    # Send cmux notification if available
    if command -v cmux &>/dev/null && [[ -n "${CMUX_WORKSPACE_ID:-}" ]]; then
      cmux notify --title "🔄 Restart Required" --body "Core files changed: ${CHANGED_FILES}" 2>/dev/null || true
    fi
  fi
fi
